{
  "expo": {
    "name": "Mawaqit | مواقيت",
    "slug": "mawaqit",
    "version": "1.2.5",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "scheme": "mawaqit",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mawaqit.app",
      "buildNumber": "25",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction for your city.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction for your city.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mawaqit.app",
      "versionCode": 25,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1a8c5b",
          "sounds": [
            "./assets/sounds/caf/Adhan-Makka-Abb.caf",
            "./assets/sounds/caf/Adhan-Madinah-Abb.caf",
            "./assets/sounds/caf/Adhan-Egypt-Abb.caf",
            "./assets/sounds/caf/Adhan-Alaqsa-Abb.caf",
            "./assets/sounds/caf/Adhan-Halab-Abb.caf",
            "./assets/sounds/caf/Al-Hussaini-Abb.caf",
            "./assets/sounds/caf/Bakir-Bash-Abb.caf",
            "./assets/sounds/caf/Abdul-Hakam-Abb.caf"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction.",
          "locationWhenInUsePermission": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "jamalal68",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5cbdb82-1df0-4afd-8015-5e50919eac1b"
      }
    }
  }
}
