{
  "expo": {
    "name": "Mawaqit | مواقيت",
    "slug": "mawaqit",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "scheme": "mawaqit",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mawaqit.app",
      "buildNumber": "30",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction for your city.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction for your city.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mawaqit.app",
      "versionCode": 26,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1a8c5b",
          "sounds": [
            "./assets/sounds/abb/adhan_makka_abb.mp3",
            "./assets/sounds/abb/adhan_madinah_abb.mp3",
            "./assets/sounds/abb/adhan_egypt_abb.mp3",
            "./assets/sounds/abb/adhan_alaqsa_abb.mp3",
            "./assets/sounds/abb/adhan_halab_abb.mp3",
            "./assets/sounds/abb/al_hussaini_abb.mp3",
            "./assets/sounds/abb/bakir_bash_abb.mp3",
            "./assets/sounds/abb/abdul_hakam_abb.mp3",
            "./assets/sounds/Adhan-Makkah.mp3",
            "./assets/sounds/Adhan-Madinah.mp3",
            "./assets/sounds/Adhan-Egypt.mp3",
            "./assets/sounds/Adhan-Alaqsa.mp3",
            "./assets/sounds/Adhan-Halab.mp3",
            "./assets/sounds/Al-Hussaini.mp3",
            "./assets/sounds/Bakir-Bash.mp3",
            "./assets/sounds/Abdul-Hakam.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction.",
          "locationWhenInUsePermission": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction."
        }
      ]
    ],
    "fonts": [
      "assets/fonts/KFGQPC-HAFS.otf",
      "assets/fonts/ScheherazadeNew-Regular.ttf",
      "assets/fonts/Amiri-Regular.ttf",
      "assets/fonts/AmiriQuran-Regular.ttf"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "jamalal68",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5cbdb82-1df0-4afd-8015-5e50919eac1b"
      }
    }
  }
}
