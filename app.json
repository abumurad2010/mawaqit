{
  "expo": {
    "name": "Mawaqit",
    "slug": "mawaqit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mawaqit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5c38"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mawaqit.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location is used to calculate accurate prayer times and Qibla direction.",
        "NSMotionUsageDescription": "Motion sensors are used to show the Qibla compass direction."
      }
    },
    "android": {
      "package": "com.mawaqit.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1a5c38",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "Mawaqit – Prayer Times & Quran",
      "shortName": "Mawaqit",
      "description": "Free Islamic prayer times, Qibla compass, and full Quran with transliteration. Works completely offline.",
      "display": "standalone",
      "orientation": "portrait",
      "themeColor": "#1a7a4a",
      "backgroundColor": "#1a5c38",
      "lang": "en",
      "scope": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow $(PRODUCT_NAME) to access your device motion for the Qibla compass."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
