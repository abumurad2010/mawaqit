{
  "expo": {
    "name": "Mawaqit | مواقيت",
    "slug": "mawaqit",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "scheme": "mawaqit",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mawaqit.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction for your city.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction for your city.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.mawaqit.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "MawaqitWidget",
              "displayName": "Mawaqit Prayer Times",
              "description": "Next prayer time and countdown",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1a8c5b",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction.",
          "locationWhenInUsePermission": "Mawaqit uses your location to calculate accurate prayer times and Qibla direction."
        }
      ],
      "expo-widgets"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "jamalal68",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5cbdb82-1df0-4afd-8015-5e50919eac1b"
      }
    }
  }
}
